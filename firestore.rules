rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // 誰でも読み取り可能（公開ページ用）
    // 書き込みは認証済みのユーザー（今回は管理者であるあなたのみ）に限定
    match /blogs/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /photos/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

  }
}
